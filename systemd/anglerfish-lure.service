[Unit]
Description=Anglerfish AI lure — native asyncssh SSH honeypot on the bait NIC
Documentation=https://github.com/retr0verride/Anglerfish-AI
# The lure forwards every command to the bridge HTTP API, so the
# bridge must be ready before we bind the bait listener; the bridge
# unit handles its own startup ordering relative to ollama.
After=network-online.target anglerfish-bridge.service
Requires=anglerfish-bridge.service
Wants=network-online.target

[Service]
Type=exec
User=anglerfish
Group=anglerfish
EnvironmentFile=/etc/anglerfish/anglerfish.env
ExecStart=/opt/anglerfish/venv/bin/anglerfish lure serve
Restart=on-failure
RestartSec=3s
TimeoutStopSec=10s

# Hardening — the lure is internet-facing on the bait NIC and
# parses arbitrary attacker SSH traffic. Apply the same sandboxing
# primitives the bridge uses, with two adjustments:
#   - CAP_NET_BIND_SERVICE is granted because operators may rebind
#     the lure to the standard SSH port (22) post-wizard via
#     ANGLERFISH_LURE__LISTEN_PORT. Default is 2222 so the
#     capability is unused on default installs; granting it
#     unconditionally avoids a fail-to-bind surprise after a
#     port swap. ProtectSystem=strict + the namespace restrictions
#     below keep the capability from being usable for anything else.
#   - ReadWritePaths includes /var/lib/anglerfish/lure-keys so
#     ensure_host_keys() can generate persistent host keys on
#     first boot (the wizard does NOT pre-generate these; the
#     lure's CLI validate-config + serve paths both call
#     ensure_host_keys at startup).
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE
ReadWritePaths=/var/lib/anglerfish /var/log/anglerfish
PrivateDevices=yes

[Install]
WantedBy=multi-user.target
