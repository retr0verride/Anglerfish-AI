# Anglerfish AI — environment configuration template.
#
# Copy to `.env` and adjust for your deployment. The first-boot wizard
# generates a fully populated `.env` for ISO deployments.
#
# Nested configuration sections use the `__` (double-underscore) delimiter,
# e.g. ANGLERFISH_OLLAMA__BASE_URL maps to settings.ollama.base_url.

# --- Global -----------------------------------------------------------------
ANGLERFISH_LOG_LEVEL=INFO
ANGLERFISH_LOG_JSON=true
ANGLERFISH_DATA_DIR=/var/lib/anglerfish

# --- Ollama (LLM inference) -------------------------------------------------
# The endpoint host MUST be either loopback (127.0.0.0/8, ::1, or "localhost")
# OR exactly equal to ANGLERFISH_OLLAMA__TRUSTED_REMOTE_HOST below.
# Hostnames other than "localhost" are rejected at validation time.
ANGLERFISH_OLLAMA__BASE_URL=http://127.0.0.1:11434/
# Optional: IP literal of a trusted remote Ollama host on the service network
# (e.g. a separate GPU box). Leave blank to enforce loopback-only.
# ANGLERFISH_OLLAMA__TRUSTED_REMOTE_HOST=10.42.0.5
ANGLERFISH_OLLAMA__MODEL=deepseek-coder:6.7b
ANGLERFISH_OLLAMA__REQUEST_TIMEOUT_S=45.0
ANGLERFISH_OLLAMA__CONNECT_TIMEOUT_S=5.0
ANGLERFISH_OLLAMA__MAX_RESPONSE_TOKENS=512
ANGLERFISH_OLLAMA__MAX_RESPONSE_CHARS=8192
ANGLERFISH_OLLAMA__TEMPERATURE=0.4
ANGLERFISH_OLLAMA__TOP_P=0.9

# --- Bridge (AI middleware) -------------------------------------------------
ANGLERFISH_BRIDGE__MAX_INPUT_CHARS=4096
ANGLERFISH_BRIDGE__HISTORY_WINDOW=20
ANGLERFISH_BRIDGE__FAKE_HOSTNAME=srv-prod-01
ANGLERFISH_BRIDGE__FAKE_USERNAME=root
ANGLERFISH_BRIDGE__FAKE_CWD=/root
ANGLERFISH_BRIDGE__ENABLE_FALLBACK=true

# --- Rate limiting (per-attacker & global) ---------------------------------
ANGLERFISH_RATE_LIMIT__MAX_CONCURRENT_REQUESTS=8
ANGLERFISH_RATE_LIMIT__REQUESTS_PER_SESSION_PER_MINUTE=30
ANGLERFISH_RATE_LIMIT__QUEUE_TIMEOUT_S=10.0

# --- Cowrie -----------------------------------------------------------------
ANGLERFISH_COWRIE__LOG_PATH=/var/log/cowrie/cowrie.json
ANGLERFISH_COWRIE__SSH_LISTEN_PORT=2222
ANGLERFISH_COWRIE__TELNET_LISTEN_PORT=2223
ANGLERFISH_COWRIE__HOSTNAME=srv-prod-01

# --- Splunk HEC forwarder ---------------------------------------------------
ANGLERFISH_SPLUNK__ENABLED=false
# ANGLERFISH_SPLUNK__HEC_URL=https://splunk.internal:8088/services/collector/event
# ANGLERFISH_SPLUNK__HEC_TOKEN=replace-with-real-token
ANGLERFISH_SPLUNK__INDEX=anglerfish
ANGLERFISH_SPLUNK__SOURCETYPE=anglerfish:session
ANGLERFISH_SPLUNK__VERIFY_TLS=true
ANGLERFISH_SPLUNK__TIMEOUT_S=10.0
ANGLERFISH_SPLUNK__FALLBACK_PATH=/var/lib/anglerfish/sessions.jsonl

# --- Dashboard --------------------------------------------------------------
ANGLERFISH_DASHBOARD__HOST=127.0.0.1
ANGLERFISH_DASHBOARD__PORT=8420
# REQUIRED: generated by the first-boot wizard. Set to a base64url-encoded
# 32-byte random value. Used for dashboard session cookies.
ANGLERFISH_DASHBOARD__SESSION_SECRET=

# --- Threat engine ----------------------------------------------------------
ANGLERFISH_THREAT__ALERT_THRESHOLD=70
# ANGLERFISH_THREAT__ALERT_WEBHOOK_URL=https://hooks.example.com/anglerfish

# --- Geo (MaxMind GeoLite2) ------------------------------------------------
# ANGLERFISH_GEO__CITY_DB_PATH=/var/lib/anglerfish/geo/GeoLite2-City.mmdb
# ANGLERFISH_GEO__ASN_DB_PATH=/var/lib/anglerfish/geo/GeoLite2-ASN.mmdb

# --- Fingerprint ------------------------------------------------------------
ANGLERFISH_FINGERPRINT__TOR_EXIT_LIST_PATH=/var/lib/anglerfish/tor-exits.txt
ANGLERFISH_FINGERPRINT__TOR_EXIT_REFRESH_INTERVAL_S=3600

# --- Credentials database ---------------------------------------------------
ANGLERFISH_CREDENTIALS__DATABASE_PATH=/var/lib/anglerfish/credentials.db
# REQUIRED: generated by the first-boot wizard. Base64-encoded 32-byte key.
ANGLERFISH_CREDENTIALS__ENCRYPTION_KEY=
